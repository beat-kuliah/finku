PORT=8080
CORS_ORIGIN=http://localhost:5173

DATABASE_URL=postgres://finku:finku@localhost:5432/finku?sslmode=disable
DB_MAX_CONNS=20
DB_MIN_CONNS=2

REDIS_URL=redis://localhost:6379/0
# Optional overrides (use when Redis requires auth and you don't want credentials in URL)
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_POOL_SIZE=20

JWT_SECRET=change-this-in-production-at-least-32-chars-long
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h

ARGON2_MEMORY_KB=19456
ARGON2_ITERATIONS=2
ARGON2_PARALLELISM=1
ARGON2_KEY_LENGTH=32
ARGON2_SALT_LENGTH=16

AUTH_RATE_LIMIT_REQUESTS=5
AUTH_RATE_LIMIT_WINDOW=1m

LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_WINDOW=15m

USER_CACHE_TTL=5m

COOKIE_SECURE=false
COOKIE_DOMAIN=
REFRESH_COOKIE_NAME=refresh_token

# OAuth providers (leave empty to disable that provider).
# Google: Web Client ID from Google Cloud Console (used as audience for ID token verification).
GOOGLE_CLIENT_ID=
